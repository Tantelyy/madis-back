generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  Int              @id @default(autoincrement()) @map("ID")
  email               String           @unique
  password            String
  userName            String
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  deletedAt           DateTime?
  roleId              Int
  role                Role             @relation(fields: [roleId], references: [id])
  userPermissions     UserPermission[]
  createdSuppliers    Supplier[]       @relation("SupplierCreatedBy")
  updatedSuppliers    Supplier[]       @relation("SupplierUpdatedBy")
  deletedSuppliers    Supplier[]       @relation("SupplierDeletedBy")
  createdProducts     Product[]        @relation("ProductCreatedBy")
  updatedProducts     Product[]        @relation("ProductUpdatedBy")
  deletedProducts     Product[]        @relation("ProductDeletedBy")
  createdPricingGrids PricingGrid[]    @relation("PricingGridCreatedBy")

  @@map("Users")
}

enum PricingGridStatus {
  ACTIVE
  ARCHIVED
  DRAFT
}

model Role {
  id              Int              @id @default(autoincrement()) @map("ID")
  label           String           @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  createdBy       Int?
  deletedBy       Int?
  users           User[]
  rolePermissions RolePermission[]

  @@map("Roles")
}

model Permission {
  id              Int              @id @default(autoincrement()) @map("ID")
  label           String
  code            String           @unique
  descriptions    String?
  createdBy       Int?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  deletedBy       Int?
  userPermissions UserPermission[]
  rolePermissions RolePermission[]

  @@map("Permissions")
}

model UserPermission {
  id           Int        @id @default(autoincrement()) @map("ID")
  userId       Int
  permissionId Int
  createdAt    DateTime   @default(now())
  createdBy    Int?
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  deletedBy    Int?
  user         User       @relation(fields: [userId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@unique([userId, permissionId])
  @@map("UserPermissions")
}

model RolePermission {
  id           Int        @id @default(autoincrement()) @map("ID")
  roleId       Int
  permissionId Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  createdBy    Int?
  deletedBy    Int?
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("RolePermissions")
}

model Supplier {
  id            Int       @id @default(autoincrement()) @map("ID")
  name          String
  address       String?
  phone         String?
  email         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  createdBy     Int
  updatedBy     Int?
  deletedBy     Int?
  createdByUser User      @relation("SupplierCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User?     @relation("SupplierUpdatedBy", fields: [updatedBy], references: [id])
  deletedByUser User?     @relation("SupplierDeletedBy", fields: [deletedBy], references: [id])

  @@map("Suppliers")
}

model ProductMark {
  id        Int       @id @default(autoincrement()) @map("ID")
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@map("ProductMarks")
}

model ProductSpecification {
  id            Int       @id @default(autoincrement()) @map("ID")
  specification String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  products      Product[]

  @@map("ProductSpecifications")
}

model ProductFormat {
  id        Int       @id @default(autoincrement()) @map("ID")
  format    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@map("ProductFormats")
}

model ProductType {
  id        Int       @id @default(autoincrement()) @map("ID")
  type      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@map("ProductTypes")
}

model Product {
  id              Int                  @id @default(autoincrement()) @map("ID")
  name            String
  reference       String               @unique
  markId          Int
  specificationId Int
  formatId        Int
  productTypeId   Int
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deletedAt       DateTime?
  deletedBy       Int?
  createdBy       Int
  image           String?
  updatedBy       Int?
  mark            ProductMark          @relation(fields: [markId], references: [id])
  specification   ProductSpecification @relation(fields: [specificationId], references: [id])
  format          ProductFormat        @relation(fields: [formatId], references: [id])
  productType     ProductType          @relation(fields: [productTypeId], references: [id])
  createdByUser   User                 @relation("ProductCreatedBy", fields: [createdBy], references: [id])
  updatedByUser   User?                @relation("ProductUpdatedBy", fields: [updatedBy], references: [id])
  deletedByUser   User?                @relation("ProductDeletedBy", fields: [deletedBy], references: [id])

  @@map("Products")
}

model PricingGrid {
  id            Int               @id @default(autoincrement()) @map("ID")
  status        PricingGridStatus
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime          @default(now())
  createdBy     Int
  updatedAt     DateTime          @updatedAt
  createdByUser User              @relation("PricingGridCreatedBy", fields: [createdBy], references: [id])
  pricingRules  PricingRule[]

  @@unique([effectiveFrom])
  @@map("PricingGrids")
}

model PricingRule {
  id                     Int         @id @default(autoincrement()) @map("ID")
  pricingGridId          Int
  minPurchasePrice       Int
  maxPurchasePrice       Int
  retailMarginPercent    Decimal     @db.Decimal(5, 2)
  wholesaleMarginPercent Decimal     @map("wholeSaleMarginPercent") @db.Decimal(5, 2)
  retailAverage          Decimal     @db.Decimal(12, 2)
  wholesaleAverage       Decimal     @map("wholeSaleAverage") @db.Decimal(12, 2)
  pricingGrid            PricingGrid @relation(fields: [pricingGridId], references: [id], onDelete: Cascade)

  @@unique([pricingGridId, minPurchasePrice, maxPurchasePrice])
  @@index([pricingGridId])
  @@map("PricingRules")
}
